# Multi-Agent Orchestrator 环境变量配置

# Claude API 配置
ANTHROPIC_API_KEY=your-api-key-here

# 数据库配置
DB_PATH=./data/orchestrator.db

# 配置根目录
CONFIG_ROOT=~/.claude

# 日志级别
LOG_LEVEL=info

# 心跳间隔（毫秒）
HEARTBEAT_INTERVAL=300000

# 监控间隔（毫秒）
MONITOR_INTERVAL=60000

# Worker 数量
WORKER_COUNT=9

# 最大任务深度
MAX_TASK_DEPTH=3
