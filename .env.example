# Multi-Agent Orchestrator 环境变量配置

# AI Provider
AI_PROVIDER=codex

# 第三方 Codex/OpenAI-compatible API 配置
AI_API_KEY=your-third-party-api-key-here
AI_BASE_URL=https://your-provider.example/v1
AI_MODEL=your-codex-compatible-model

# Telegram Bot 配置（可选，用于 examples/telegram-bot.ts）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PROXY_URL=

# Feishu Bot 配置（可选，用于 examples/feishu-bot.ts）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=
FEISHU_VERIFICATION_TOKEN=
FEISHU_CHAT_ID=
FEISHU_EVENT_HOST=0.0.0.0
FEISHU_EVENT_PORT=8788
FEISHU_EVENT_PATH=/feishu/events
FEISHU_EXECUTION_UPDATES_MODE=silent

WORKSPACE_ROOT=
PROJECT_SEARCH_ROOTS=
ENABLE_WORKSPACE_EXECUTION=true
MAX_EXECUTION_ITERATIONS=6
COMMAND_TIMEOUT_MS=120000


# 数据库配置
DB_PATH=./data/orchestrator.db

# 配置根目录
CONFIG_ROOT=~/.codex

# 日志级别
LOG_LEVEL=info

# API 配置
API_TIMEOUT_MS=120000
MAX_RETRIES=3
MAX_OUTPUT_TOKENS=16384

# 心跳间隔（毫秒）
HEARTBEAT_INTERVAL=300000

# 监控间隔（毫秒）
MONITOR_INTERVAL=60000

# Worker 数量
WORKER_COUNT=9

# 最大任务深度
MAX_TASK_DEPTH=3
